<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeteoPortugal.App.Views.ObservationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:MeteoPortugal.App.Components"
    Title="Observação"
    BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackground}, Dark={StaticResource DarkColorBackground}}">
    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="18">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <Label
                        FontFamily="{StaticResource FontFamilyBold}"
                        FontSize="30"
                        Text="{Binding Title}"
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                    <Label
                        Grid.Row="1"
                        FontSize="15"
                        Text="{Binding LastUpdated}"
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                    <Border
                        Grid.Column="1"
                        Grid.RowSpan="2"
                        Padding="10,6"
                        Style="{StaticResource WeatherBadgeBorder}"
                        VerticalOptions="Center">
                        <Label
                            FontFamily="{StaticResource FontFamilySemiBold}"
                            FontSize="12"
                            Text="{Binding LocationName}"
                            TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}" />
                    </Border>
                </Grid>

                <Border Padding="14" Style="{StaticResource WeatherCardBorder}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label
                            FontFamily="{StaticResource FontFamilySemiBold}"
                            Text="Produto"
                            TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}"
                            VerticalTextAlignment="Center" />
                        <Picker
                            Grid.Column="1"
                            ItemsSource="{Binding Modes}"
                            SelectedItem="{Binding SelectedMode}" />
                    </Grid>
                </Border>

                <Border
                    IsVisible="{Binding HasStatusMessage}"
                    Padding="14"
                    Style="{StaticResource StatusWarningBorder}">
                    <Label
                        FontSize="13"
                        Text="{Binding StatusMessage}"
                        TextColor="{AppThemeBinding Light={StaticResource ColorWarningText}, Dark={StaticResource DarkColorWarningText}}" />
                </Border>

                <VerticalStackLayout IsVisible="{Binding IsMapVisible}" Spacing="16">
                    <components:ObservationStationMap Stations="{Binding Stations}" />

                    <Label
                        Style="{StaticResource SectionTitleLabel}"
                        Text="Estações próximas" />

                    <CollectionView ItemsSource="{Binding Stations}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="16"
                                    Style="{StaticResource WeatherCardBorder}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                        <VerticalStackLayout Spacing="2">
                                            <Label
                                                FontFamily="{StaticResource FontFamilySemiBold}"
                                                FontSize="17"
                                                Text="{Binding Name}"
                                                TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                                            <Label
                                                FontSize="12"
                                                Text="{Binding DistanceKm, StringFormat='{0:F1} km de distância'}"
                                                TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                                        </VerticalStackLayout>

                                        <Label
                                            Grid.Column="1"
                                            FontFamily="{StaticResource FontFamilyBold}"
                                            FontSize="28"
                                            Text="{Binding TemperatureCelsius, StringFormat='{0:F1}&#176;'}"
                                            TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}" />

                                        <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                            <Label Text="{Binding HumidityPercent, StringFormat='Hum {0:F0}%'}" TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                                            <Label Grid.Column="1" Text="{Binding WindSpeedKmh, StringFormat='Vento {0:F0} km/h'}" TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                                            <Label Grid.Column="2" Text="{Binding PressureHpa, StringFormat='{0:F0} hPa'}" TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                                        </Grid>

                                        <Label
                                            Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            FontSize="12"
                                            Text="{Binding ObservedAt, StringFormat='Observado {0}'}"
                                            TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsRemoteVisible}" Spacing="12">
                    <Label
                        Style="{StaticResource SectionTitleLabel}"
                        Text="{Binding RemoteTitle}" />
                    <Border
                        HeightRequest="520"
                        Style="{StaticResource WeatherCardBorder}">
                        <WebView Source="{Binding RemoteSource}" />
                    </Border>
                    <Label
                        FontSize="12"
                        Text="Conteúdo remoto oficial do IPMA. A disponibilidade e o formato podem variar."
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
