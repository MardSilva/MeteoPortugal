<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeteoPortugal.App.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Bem-vindo"
    BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackground}, Dark={StaticResource DarkColorBackground}}">
    <Grid Padding="24" RowDefinitions="Auto,*,Auto" RowSpacing="20">
        <VerticalStackLayout Spacing="16">
            <Image
                HeightRequest="56"
                HorizontalOptions="Start"
                Source="meteo_portugal_logo.svg"
                WidthRequest="230" />

            <VerticalStackLayout Spacing="8">
                <Label
                    FontFamily="{StaticResource FontFamilyBold}"
                    FontSize="32"
                    Text="{Binding Title}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                <Label
                    FontSize="16"
                    Text="{Binding Subtitle}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
            </VerticalStackLayout>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Style="{StaticResource SectionTitleLabel}"
                    Text="Localização inicial" />
                <Label
                    Grid.Column="1"
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    FontSize="13"
                    Text="{Binding LocationCount, StringFormat='{0} locais IPMA'}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}" />
            </Grid>

            <Border
                Padding="4"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurface}, Dark={StaticResource DarkColorSurface}}"
                Stroke="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <SearchBar
                    Placeholder="Pesquisar localidade"
                    Text="{Binding SearchText}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
            </Border>

            <CollectionView
                IsGrouped="True"
                ItemsSource="{Binding GroupedLocations}"
                SelectedItem="{Binding SelectedLocation}"
                SelectionMode="Single">
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate>
                        <Label
                            Padding="2,8,2,6"
                            FontFamily="{StaticResource FontFamilySemiBold}"
                            FontSize="13"
                            Text="{Binding Name}"
                            TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>
                <CollectionView.EmptyView>
                    <Label
                        Padding="0,24"
                        HorizontalTextAlignment="Center"
                        Text="Sem localidades encontradas."
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            Padding="16"
                            Style="{StaticResource WeatherCardBorder}">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                                <Label
                                    FontFamily="{StaticResource FontFamilySemiBold}"
                                    FontSize="19"
                                    Text="{Binding Name}"
                                    TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                                <Label
                                    Grid.Row="1"
                                    FontSize="13"
                                    Text="{Binding District, StringFormat='Região {0}'}"
                                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                                <Label
                                    Grid.Column="1"
                                    Grid.RowSpan="2"
                                    FontFamily="{StaticResource FontFamilySemiBold}"
                                    Text="Escolher"
                                    TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}"
                                    VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <Button
            Grid.Row="2"
            Command="{Binding ContinueCommand}"
            Text="Continuar" />
    </Grid>
</ContentPage>
