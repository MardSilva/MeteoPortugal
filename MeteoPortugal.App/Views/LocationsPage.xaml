<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeteoPortugal.App.Views.LocationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:MeteoPortugal.App.Components"
    Title="Locais"
    BackgroundColor="{AppThemeBinding Light={StaticResource ColorBackground}, Dark={StaticResource DarkColorBackground}}">
    <RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsLoading}">
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="18">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <Label
                        FontFamily="{StaticResource FontFamilyBold}"
                        FontSize="30"
                        Text="Escolha a localidade"
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                    <Border
                        Grid.Column="1"
                        Padding="10,6"
                        Style="{StaticResource WeatherBadgeBorder}"
                        VerticalOptions="Center">
                        <Label
                            FontFamily="{StaticResource FontFamilySemiBold}"
                            FontSize="12"
                            Text="{Binding LocationCount, StringFormat='{0} locais'}"
                            TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}" />
                    </Border>
                    <Label
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        FontSize="15"
                        Text="Pesquise e acompanhe as cidades guardadas."
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                </Grid>

                <Border
                    Padding="4"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurface}, Dark={StaticResource DarkColorSurface}}"
                    Stroke="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <SearchBar
                        CancelButtonColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}"
                        Placeholder="Pesquisar localidade"
                        SearchCommand="{Binding LoadCommand}"
                        Text="{Binding SearchText}"
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                </Border>

                <CollectionView ItemsSource="{Binding Locations}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="0,32" Spacing="8">
                            <Label
                                FontFamily="{StaticResource FontFamilySemiBold}"
                                FontSize="18"
                                HorizontalTextAlignment="Center"
                                Text="Sem resultados"
                                TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                            <Label
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                Text="Tente pesquisar Lisboa ou Porto."
                                TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <components:LocationWeatherCard Margin="0,0,0,12" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
