<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeteoPortugal.App.Views.DailyInfoEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Info diaria"
    BackgroundColor="#F4F8FB">
    <VerticalStackLayout Padding="24" Spacing="12">
        <Label FontAttributes="Bold" FontSize="28" Text="{Binding Title}" TextColor="#102A43" />
        <Label FontSize="16" Text="{Binding Message}" TextColor="#5B6773" />
    </VerticalStackLayout>
</ContentPage>
