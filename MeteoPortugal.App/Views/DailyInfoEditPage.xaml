<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeteoPortugal.App.Views.DailyInfoEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Info diária"
    BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceAlt}, Dark={StaticResource DarkColorBackground}}">
    <VerticalStackLayout Padding="24" Spacing="12">
        <Label FontFamily="{StaticResource FontFamilyBold}" FontSize="28" Text="{Binding Title}" TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
        <Label FontSize="16" Text="{Binding Message}" TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
    </VerticalStackLayout>
</ContentPage>
