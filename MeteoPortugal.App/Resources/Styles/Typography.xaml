<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Label" x:Key="PageTitleLabel">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyBold}" />
        <Setter Property="FontSize" Value="{StaticResource FontPageTitle}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
    </Style>

    <Style TargetType="Label" x:Key="SectionTitleLabel">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySemiBold}" />
        <Setter Property="FontSize" Value="{StaticResource FontSection}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
    </Style>

    <Style TargetType="Label" x:Key="MutedBodyLabel">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
    </Style>

    <Style TargetType="Label" x:Key="WeatherMutedLabel">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontBody}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
    </Style>
</ResourceDictionary>
