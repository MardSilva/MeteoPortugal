<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MeteoPortugal.App.Components.WeatherWarningCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border Padding="16" Style="{StaticResource StatusWarningBorder}">
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
            <Border
                Grid.RowSpan="3"
                BackgroundColor="{AppThemeBinding Light={StaticResource ColorWarning}, Dark={StaticResource DarkColorWarning}}"
                HeightRequest="34"
                StrokeThickness="0"
                VerticalOptions="Start"
                WidthRequest="34">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    HorizontalTextAlignment="Center"
                    Text="!"
                    TextColor="White"
                    VerticalTextAlignment="Center" />
            </Border>

            <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                <Label
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    FontSize="16"
                    Text="{Binding Type}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                <Label
                    Grid.Column="1"
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    FontSize="12"
                    Text="{Binding Level}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorWarningText}, Dark={StaticResource DarkColorWarningText}}" />
            </Grid>

            <Label
                Grid.Column="1"
                Grid.Row="1"
                FontSize="13"
                Text="{Binding Text}"
                TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />

            <Label
                Grid.Column="1"
                Grid.Row="2"
                FontSize="12"
                TextColor="{AppThemeBinding Light={StaticResource ColorWarningText}, Dark={StaticResource DarkColorWarningText}}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="De " />
                        <Span Text="{Binding StartsAt}" />
                        <Span Text=" a " />
                        <Span Text="{Binding EndsAt}" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Grid>
    </Border>
</ContentView>
