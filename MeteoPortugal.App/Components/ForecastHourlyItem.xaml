<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MeteoPortugal.App.Components.ForecastHourlyItem"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border
        Padding="14"
        Style="{StaticResource WeatherCardBorder}"
        WidthRequest="112">
        <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
            <Label
                HorizontalTextAlignment="Center"
                Text="{Binding Time}"
                TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
            <Image HeightRequest="34" Source="{Binding WeatherIcon}" WidthRequest="34" />
            <Label
                FontFamily="{StaticResource FontFamilySemiBold}"
                HorizontalTextAlignment="Center"
                Text="{Binding TemperatureCelsius, StringFormat='{0:F0}&#176;C'}"
                TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
            <Label
                FontSize="12"
                HorizontalTextAlignment="Center"
                Text="{Binding Condition}"
                TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
