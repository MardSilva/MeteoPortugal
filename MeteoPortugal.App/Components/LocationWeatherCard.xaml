<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MeteoPortugal.App.Components.LocationWeatherCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border Padding="18" Style="{StaticResource WeatherCardBorder}">
        <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    FontSize="20"
                    Text="{Binding Location.Name}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                <Label
                    FontSize="13"
                    Text="{Binding Location.District}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
            </VerticalStackLayout>

            <Image
                Grid.Column="1"
                Grid.RowSpan="2"
                HeightRequest="48"
                Source="{Binding WeatherIcon}"
                VerticalOptions="Start"
                WidthRequest="48" />

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" Spacing="0">
                <Label
                    FontFamily="{StaticResource FontFamilyBold}"
                    FontSize="34"
                    HorizontalTextAlignment="End"
                    Text="{Binding TemperatureCelsius, StringFormat='{0:F0}&#176;'}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}" />
                <Label
                    FontSize="12"
                    HorizontalTextAlignment="End"
                    Text="{Binding Condition}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
            </VerticalStackLayout>

            <Grid Grid.Row="1" Grid.ColumnSpan="3" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Border Padding="10,8" BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceAlt}, Dark={StaticResource DarkColorSurfaceAlt}}" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label FontSize="11" Text="Max/Min" TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                        <Label FontFamily="{StaticResource FontFamilySemiBold}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding MaximumTemperatureCelsius, StringFormat='{0:F0}&#176;'}" />
                                    <Span Text=" / " />
                                    <Span Text="{Binding MinimumTemperatureCelsius, StringFormat='{0:F0}&#176;'}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Padding="10,8" BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceAlt}, Dark={StaticResource DarkColorSurfaceAlt}}" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label FontSize="11" Text="Vento" TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                        <Label FontFamily="{StaticResource FontFamilySemiBold}" FontSize="13" Text="{Binding WindSpeedKmh, StringFormat='{0:F0} km/h'}" TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" Padding="10,8" BackgroundColor="{AppThemeBinding Light={StaticResource ColorSurfaceAlt}, Dark={StaticResource DarkColorSurfaceAlt}}" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label FontSize="11" Text="Chuva" TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                        <Label FontFamily="{StaticResource FontFamilySemiBold}" FontSize="13" Text="{Binding PrecipitationProbabilityPercent, StringFormat='{0}%'}" TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Grid.ColumnSpan="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <Ellipse Fill="{AppThemeBinding Light={StaticResource ColorSun}, Dark={StaticResource DarkColorSun}}" HeightRequest="9" WidthRequest="9" VerticalOptions="Center" />
                <Label
                    Grid.Column="1"
                    FontSize="12"
                    Text="{Binding UpdatedAt}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                <Label
                    Grid.Column="2"
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    FontSize="12"
                    Text="{Binding UvIndex, StringFormat='UV {0}'}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorPrimary}, Dark={StaticResource DarkColorPrimary}}" />
            </Grid>
        </Grid>
    </Border>
</ContentView>
