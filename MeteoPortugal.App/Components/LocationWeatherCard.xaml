<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MeteoPortugal.App.Components.LocationWeatherCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border Padding="18" Style="{StaticResource WeatherCardBorder}">
        <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
            <VerticalStackLayout Spacing="2">
                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    Text="{Binding Location.Name}"
                    TextColor="{StaticResource WeatherText}" />
                <Label
                    FontSize="13"
                    Text="{Binding Location.District}"
                    TextColor="{StaticResource WeatherMutedText}" />
            </VerticalStackLayout>

            <Image
                Grid.Column="1"
                Grid.RowSpan="2"
                HeightRequest="48"
                Source="{Binding WeatherIcon}"
                VerticalOptions="Start"
                WidthRequest="48" />

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" Spacing="0">
                <Label
                    FontAttributes="Bold"
                    FontSize="34"
                    HorizontalTextAlignment="End"
                    Text="{Binding TemperatureCelsius, StringFormat='{0:F0}&#176;'}"
                    TextColor="{StaticResource WeatherBlue}" />
                <Label
                    FontSize="12"
                    HorizontalTextAlignment="End"
                    Text="{Binding Condition}"
                    TextColor="{StaticResource WeatherMutedText}" />
            </VerticalStackLayout>

            <Grid Grid.Row="1" Grid.ColumnSpan="3" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Border Padding="10,8" BackgroundColor="#F4F8FB" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label FontSize="11" Text="Max/Min" TextColor="{StaticResource WeatherMutedText}" />
                        <Label FontAttributes="Bold" FontSize="13" TextColor="{StaticResource WeatherText}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding MaximumTemperatureCelsius, StringFormat='{0:F0}&#176;'}" />
                                    <Span Text=" / " />
                                    <Span Text="{Binding MinimumTemperatureCelsius, StringFormat='{0:F0}&#176;'}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Padding="10,8" BackgroundColor="#F4F8FB" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label FontSize="11" Text="Vento" TextColor="{StaticResource WeatherMutedText}" />
                        <Label FontAttributes="Bold" FontSize="13" Text="{Binding WindSpeedKmh, StringFormat='{0:F0} km/h'}" TextColor="{StaticResource WeatherText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" Padding="10,8" BackgroundColor="#F4F8FB" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="2">
                        <Label FontSize="11" Text="Chuva" TextColor="{StaticResource WeatherMutedText}" />
                        <Label FontAttributes="Bold" FontSize="13" Text="{Binding PrecipitationProbabilityPercent, StringFormat='{0}%'}" TextColor="{StaticResource WeatherText}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Grid.ColumnSpan="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <Ellipse Fill="{StaticResource WeatherSun}" HeightRequest="9" WidthRequest="9" VerticalOptions="Center" />
                <Label
                    Grid.Column="1"
                    FontSize="12"
                    Text="{Binding UpdatedAt}"
                    TextColor="{StaticResource WeatherMutedText}" />
                <Label
                    Grid.Column="2"
                    FontAttributes="Bold"
                    FontSize="12"
                    Text="{Binding UvIndex, StringFormat='UV {0}'}"
                    TextColor="{StaticResource WeatherBlue}" />
            </Grid>
        </Grid>
    </Border>
</ContentView>
