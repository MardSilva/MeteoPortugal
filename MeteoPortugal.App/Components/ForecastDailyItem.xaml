<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MeteoPortugal.App.Components.ForecastDailyItem"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border Padding="16" Style="{StaticResource WeatherCardBorder}">
        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
            <Image
                Grid.RowSpan="2"
                HeightRequest="38"
                Source="{Binding WeatherIcon}"
                VerticalOptions="Center"
                WidthRequest="38" />
            <Label
                Grid.Column="1"
                FontFamily="{StaticResource FontFamilySemiBold}"
                Text="{Binding Day}"
                TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
            <Label
                Grid.Column="1"
                Grid.Row="1"
                Text="{Binding Condition}"
                TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
            <HorizontalStackLayout Grid.Column="2" Grid.RowSpan="2" Spacing="2">
                <Label
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    Text="{Binding MaximumTemperatureCelsius, StringFormat='{0:F0}&#176;'}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                <Label
                    Text="/"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
                <Label
                    Text="{Binding MinimumTemperatureCelsius, StringFormat='{0:F0}&#176;'}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>
