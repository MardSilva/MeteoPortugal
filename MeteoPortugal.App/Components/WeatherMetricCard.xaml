<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="MeteoPortugal.App.Components.WeatherMetricCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border Padding="16" Style="{StaticResource WeatherCardBorder}">
        <VerticalStackLayout Spacing="4">
            <Label
                FontSize="13"
                Text="{Binding Title}"
                TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}" />
            <HorizontalStackLayout Spacing="4">
                <Label
                    FontFamily="{StaticResource FontFamilySemiBold}"
                    FontSize="22"
                    Text="{Binding Value}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextPrimary}, Dark={StaticResource DarkColorTextPrimary}}" />
                <Label
                    FontSize="14"
                    Text="{Binding Unit}"
                    TextColor="{AppThemeBinding Light={StaticResource ColorTextSecondary}, Dark={StaticResource DarkColorTextSecondary}}"
                    VerticalTextAlignment="End" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
